{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Python: Create venv",
      "type": "shell",
      "command": "py -m venv .venv",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Python: Install requirements",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe -m pip install -r requirements.txt",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Pipeline: Daily ingest (script)",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run_daily_ingest.ps1 -Symbols TQQQ -CallPut P -Dte 100 -Deltas -0.17",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Pipeline: Health check",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File .\\scripts\\health_check.ps1",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
