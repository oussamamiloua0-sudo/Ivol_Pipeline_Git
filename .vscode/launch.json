{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: main.py run daily_ingest",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/main.py",
      "args": [
        "run",
        "daily_ingest",
        "--symbols",
        "TQQQ",
        "--dte",
        "100",
        "--callput",
        "P",
        "--deltas",
        "-0.17"
      ],
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "Python: jobs/daily_ingest.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/jobs/daily_ingest.py",
      "args": [
        "--symbols",
        "TQQQ",
        "--callput",
        "P",
        "--dte",
        "100",
        "--deltas",
        "-0.17"
      ],
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "Python: jobs/load_options_from_nearest_to_db.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/jobs/load_options_from_nearest_to_db.py",
      "args": [
        "--symbol",
        "TQQQ",
        "--date",
        "2022-03-15",
        "--dte",
        "100",
        "--callput",
        "P",
        "--delta",
        "-0.17"
      ],
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    }
  ]
}
