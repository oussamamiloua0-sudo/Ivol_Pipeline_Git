# ---------------------------------------------------------------------------
# iVolatility API keys
# ---------------------------------------------------------------------------

# Single key (backward-compatible, always works)
IVOL_API_KEY=

# Multi-key pool for parallel backfills (comma-separated, no spaces).
# When set, IVOL_API_KEY is also included automatically (deduped).
# Example: IVOL_API_KEYS=key1,key2,key3,key4,key5
IVOL_API_KEYS=

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# SQLAlchemy MySQL URL for DigitalOcean Managed MySQL (port 25060, SSL)
DB_URL=mysql+pymysql://user:password@host:25060/dbname

# ---------------------------------------------------------------------------
# Optional overrides (safe to leave commented out)
# ---------------------------------------------------------------------------

# Override iVol REST API base URL (default: https://restapi.ivolatility.com)
# IVOL_BASE_URL=

# SSL / connectivity (defaults are correct for DO Managed MySQL)
# DB_SSL_MODE=REQUIRED        # REQUIRED | DISABLED
# DB_SSL_CA=do-mysql-ca.crt.crt
# DB_CONNECT_TIMEOUT=15
# DB_READ_TIMEOUT=60
# DB_WRITE_TIMEOUT=60
# DB_TCP_PREFLIGHT=1          # set to 0 to skip the TCP ping on startup
# DB_HOST=                    # override host parsed from DB_URL
# DB_PORT=                    # override port parsed from DB_URL
