# Required
IVOL_API_KEY=
DB_URL=

# Optional: use these only if you don't have an API key
# IVOL_USERNAME=
# IVOL_PASSWORD=
# IVOL_TOKEN=

# Optional: leave unset to use defaults in code
# IVOL_BASE_URL=
# REGION=
# SYMBOLS_FILE=
# RAW_DIR=
# LOG_DIR=

# Optional: DB connectivity tweaks (defaults are fine for most users)
# DB_SSL_MODE=
# DB_SSL_CA=
# DB_CONNECT_TIMEOUT=
# DB_READ_TIMEOUT=
# DB_WRITE_TIMEOUT=
# DB_TCP_PREFLIGHT=
# DB_HOST=
# DB_PORT=
